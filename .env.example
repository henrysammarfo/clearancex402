# Clearance402 — Base Sepolia (chain 84532)
# Copy to .env.local — never commit secrets.

# --- Browser (VITE_ prefix — safe in client bundle) ---
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_CLEARANCE_CHAIN_ID=84532
VITE_EXPLORER_TX_URL=https://sepolia.basescan.org/tx/
# https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=
VITE_APP_ENV=development
# Production: your Vercel URL (defaults to window.location.origin)
VITE_CLEARANCE_API_URL=

# --- Server only (no VITE_ prefix) ---
# Fund with Base Sepolia ETH + USDC: https://faucet.circle.com
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
WALLET_PRIVATE_KEY=0x...

# Venice — https://venice.ai/settings/api (judges: add key for live eval; heuristic fallback without credits)
VENICE_API_KEY=
VENICE_API_URL=https://api.venice.ai/api/v1

# Production persistence — Vercel Postgres auto-injects POSTGRES_URL when storage is linked.
# You can also set DATABASE_URL manually (same connection string).
DATABASE_URL=
POSTGRES_URL=

# Encrypt agent session keys at rest (min 16 chars — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
SESSION_ENCRYPTION_SECRET=

# SDK / CLI / MCP → your deployed API
CLEARANCE402_API_URL=https://clearancex402.vercel.app

# CLI / MCP wallet scope (0x… address)
CLEARANCE402_WALLET=0x...

# Local dev file store fallback (when DATABASE_URL unset)
# CLEARANCE_STORE_PATH=.data/clearance-platform.json
