# Line Stack — Aeneid (Story testnet) configuration
# Copy to .env.local — never commit secrets.
# Sources: https://docs.story.foundation/developers/cdr-sdk/setup

# --- Public (safe for VITE_ prefix in browser) ---
STORY_RPC_URL=https://aeneid.storyrpc.io
STORY_API_URL=http://172.192.41.96:1317
STORY_NETWORK=testnet
STORY_CHAIN_ID=1315
STORY_EXPLORER_TX_URL=https://aeneid.storyscan.io/tx/

VITE_STORY_RPC_URL=https://aeneid.storyrpc.io
VITE_STORY_API_URL=http://172.192.41.96:1317
VITE_STORY_CHAIN_ID=1315
VITE_STORY_EXPLORER_TX_URL=https://aeneid.storyscan.io/tx/

# Required: WalletConnect Cloud project id (full RainbowKit wallet modal)
# https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=

# --- CDR client tuning ---
CDR_TIMEOUT_MS=120000
# CDR_MIN_THRESHOLD_RATIO=0.67

# --- Logging ---
LOG_LEVEL=info

# --- Server / CLI / integration tests ONLY (NEVER use VITE_ prefix) ---
# Fund via https://faucet.story.foundation
# WALLET_PRIVATE_KEY=0x...
# BUYER_WALLET_PRIVATE_KEY=0x...   # optional; smoke-e2e generates + funds if unset

# Optional: Intel DCAP quote for Automata on-chain attestation on fulfill (Aeneid)
# AUTOMATA_DCAP_QUOTE_HEX=0x...
# USE_AUTOMATA_DCAP_FIXTURE=1   # required on Vercel — fixtures/automata/alibaba-v5-quote.hex
# AUTOMATA_DCAP_QUOTE_FILE=fixtures/automata/v4-tdx-quote.hex

# --- Optional: Alchemy RPC (recommended if public RPC is slow) ---
# ALCHEMY_API_KEY=your_key_here
# STORY_RPC_URL=https://story-aeneid.g.alchemy.com/v2/your_key_here
# VITE_STORY_RPC_URL=https://story-aeneid.g.alchemy.com/v2/your_key_here

# --- IPFS on your VPS (recommended — see docs/IPFS-VPS.md) ---
# IPFS_PROXY_URL=http://YOUR_VPS:8787
# IPFS_PROXY_SECRET=
# IPFS_GATEWAY_URL=http://YOUR_VPS:8080/ipfs

# --- Shared registry on VPS (vaults, listings, queryline — see docs/REGISTRY-VPS.md) ---
# REGISTRY_API_URL=http://YOUR_VPS:8788
# REGISTRY_PROXY_SECRET=   # can match IPFS_PROXY_SECRET

# --- Storacha (optional fallback — see docs/STORACHA-CLI.md) ---
# After `storacha space create` + `storacha key create` + `storacha delegation create … --base64`:
# STORACHA_PRINCIPAL=MgCa...   # `key` from storacha key create --json
# STORACHA_PROOF=mAYIE...      # base64 from storacha delegation create

# Optional Vite-exposed app label only (never put proof in VITE_*)
# VITE_APP_ENV=production

# --- Integration test gate ---
# RUN_CDR_INTEGRATION=1

# --- Line Stack on-chain registries (after deploy — docs/CONTRACTS.md) ---
# VITE_LINESTACK_DATASET_REGISTRY=0x...
# VITE_LINESTACK_TEMPLATE_REGISTRY=0x...
# LINESTACK_DATASET_REGISTRY=0x...
# LINESTACK_TEMPLATE_REGISTRY=0x...
# LINESTACK_PUBLISHER_WRITE_CONDITION=0x...
# LINESTACK_BUYER_READ_CONDITION=0x...
# LINESTACK_MERKLE_ALLOWLIST_READ_CONDITION=0x...
# LINESTACK_BETA_MERKLE_ROOT=0x...

# --- Published CLI / MCP (copy to ~/.linestack/.env after npm install -g) ---
# LINESTACK_ENV_FILE=C:\Users\YOU\.linestack\.env
# LINESTACK_STATE_FILE=C:\Users\YOU\.linestack\state.json
# REGISTRY_API_URL=http://YOUR_VPS:8788
# REGISTRY_PROXY_SECRET=
# LINESTACK_DATASET_REGISTRY=0x...
# LINESTACK_TEMPLATE_REGISTRY=0x...
