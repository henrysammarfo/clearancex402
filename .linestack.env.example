# Copy to ~/.linestack/.env (chmod 600). Never commit.
# Used by: @line-stack/cli, @line-stack/mcp-server, @line-stack/sdk
# Docs: docs/AGENT-INTEGRATIONS.md

WALLET_PRIVATE_KEY=0x...
STORY_RPC_URL=https://aeneid.storyrpc.io
STORY_CHAIN_ID=1315

# Optional second wallet for buyer flows (E2E scripts)
# BUYER_WALLET_PRIVATE_KEY=0x...

# VPS IPFS (required for file upload/unlock)
IPFS_PROXY_URL=http://64.176.181.71:8787
IPFS_PROXY_SECRET=
IPFS_GATEWAY_URL=http://64.176.181.71:8080/ipfs

# Shared registry (same as web app — linestack.vercel.app)
REGISTRY_API_URL=http://64.176.181.71:8788
REGISTRY_PROXY_SECRET=

# On-chain registries (contracts/deployed.aeneid.json)
LINESTACK_DATASET_REGISTRY=0x176018c6c8c445807fe3688f463487e4b01c8ae3
LINESTACK_TEMPLATE_REGISTRY=0xe39d684dede7d04c063121878c6c52a223b82e0c
LINESTACK_PUBLISHER_WRITE_CONDITION=0xcfe325f00cf0e3b727680f7727b81aaa1c4dcfe0
LINESTACK_BUYER_READ_CONDITION=0xcd3a4992c0de81ceb78cf9b58bd76c31bcf08792
LINESTACK_MERKLE_ALLOWLIST_READ_CONDITION=0x0e872eb23deb91da38e5f53a042cf1818cf4bc11

# Storacha — required for: linestack vaultline register-ip / vaultline_register_ip
STORACHA_PROOF=

# Queryline fulfill — Automata DCAP on-chain (CLI/MCP; web uses Vercel /api/automata/quote)
USE_AUTOMATA_DCAP_FIXTURE=1
# AUTOMATA_DCAP_QUOTE_FILE=fixtures/automata/alibaba-v5-quote.hex
# Or your TEE quote (unset USE_AUTOMATA_DCAP_FIXTURE):
# AUTOMATA_DCAP_QUOTE_HEX=0x...

# Optional explicit env path for MCP hosts
# LINESTACK_ENV_FILE=C:/Users/YOU/.linestack/.env
