{
  "name": "line-stack",
  "author": "henrysammarfo <jasonneil4040@gmail.com>",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:core": "npm run build --workspace=@line-stack/cdr-core",
    "build:sdk": "npm run build --workspace=@line-stack/sdk",
    "build:cli": "npm run build --workspace=@line-stack/cli",
    "build:mcp": "npm run build --workspace=@line-stack/mcp-server",
    "build:packages": "npm run build:core && npm run build:sdk && npm run build:cli && npm run build:mcp",
    "linestack": "node packages/cli/dist/index.js",
    "linestack:mcp": "node packages/mcp-server/dist/index.js",
    "verify:publish": "node scripts/verify-npm-package.mjs packages/cdr-core && node scripts/verify-npm-package.mjs packages/sdk && node scripts/verify-npm-package.mjs packages/cli && node scripts/verify-npm-package.mjs packages/mcp-server",
    "publish:packages": "node scripts/publish-packages.mjs",
    "publish:packages:dry-run": "node scripts/publish-packages.mjs --dry-run",
    "compile:contracts": "node scripts/compile-linestack-contracts.mjs",
    "deploy:contracts": "node scripts/deploy-linestack-contracts.mjs",
    "deploy:contracts:vps": "powershell -ExecutionPolicy Bypass -File scripts/deploy-contracts-vps.ps1",
    "hackathon:check": "node scripts/run-hackathon-checks.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck:core",
    "typecheck:core": "npm run typecheck --workspace=@line-stack/cdr-core",
    "test:core": "npm run test --workspace=@line-stack/cdr-core",
    "test:core:integration": "npm run test:integration --workspace=@line-stack/cdr-core",
    "test:smoke": "node scripts/smoke-env.mjs",
    "test:storacha": "node scripts/verify-storacha-delegation.mjs",
    "test:ipfs": "node scripts/test-ipfs-proxy.mjs",
    "test:registry": "node scripts/test-registry-api.mjs",
    "hackathon:smoke": "node scripts/run-hackathon-smoke.mjs",
    "deploy:registry-vps": "powershell -ExecutionPolicy Bypass -File scripts/deploy-registry-vps.ps1",
    "test:beta-env": "node scripts/verify-beta-env.mjs",
    "beta:patch-env": "node scripts/patch-env-contracts.mjs && node scripts/patch-env-registry.mjs",
    "setup:git-hooks": "node scripts/setup-git-hooks.mjs",
    "setup:agents": "node scripts/setup-agents.mjs",
    "vercel:import-env": "node scripts/generate-vercel-import.mjs",
    "vercel:import-cleanup": "node scripts/delete-vercel-import.mjs",
    "vercel:check": "node scripts/verify-vercel-install.mjs && npm run build:core",
    "test:phase3b": "node scripts/test-phase3b-license.mjs",
    "postinstall": "node scripts/patch-one-webcrypto.mjs",
    "test:e2e": "node scripts/patch-one-webcrypto.mjs && node scripts/smoke-e2e-full.mjs",
    "test:e2e:queryline": "node scripts/patch-one-webcrypto.mjs && node scripts/smoke-e2e-full.mjs --skip-vaultline",
    "test:e2e:automata": "node scripts/patch-one-webcrypto.mjs && node scripts/smoke-e2e-full.mjs --skip-vaultline --automata",
    "demo:automata": "node scripts/patch-one-webcrypto.mjs && npm run build:core && npm run build:sdk && node scripts/demo-automata-fulfill.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@line-stack/cdr-core": "file:packages/cdr-core",
    "@piplabs/cdr-sdk": "^0.2.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@storacha/client": "^1.8.26",
    "@story-protocol/core-sdk": "^1.4.4",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/router-plugin": "^1.167.28",
    "@ucanto/principal": "^9.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "multiformats": "13.4.2",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.76.1",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "shaders": "^2.5.128",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "viem": "^2.47.6",
    "vite-tsconfig-paths": "^6.0.2",
    "wagmi": "^2.17.5",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@story-protocol/core-sdk": {
      "multiformats": "9.9.0"
    },
    "@ucanto/core": "10.4.6",
    "@ucanto/validator": "10.0.1",
    "@ucanto/principal": "9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "nitro": "3.0.260429-beta",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
