{
  "name": "@line-stack/cdr-core",
  "version": "0.1.1",
  "description": "Line Stack wrapper for Story Confidential Data Rails (@piplabs/cdr-sdk)",
  "type": "module",
  "license": "MIT",
  "author": "Line Stack",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henrysammarfo/linestack.git",
    "directory": "packages/cdr-core"
  },
  "bugs": "https://github.com/henrysammarfo/linestack/issues",
  "homepage": "https://github.com/henrysammarfo/linestack/tree/main/packages/cdr-core#readme",
  "keywords": ["story", "cdr", "confidential-data-rails", "aeneid", "linestack"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./attestation/browser": {
      "types": "./dist/attestation/browser.d.ts",
      "import": "./dist/attestation/browser.js"
    },
    "./quote": {
      "types": "./dist/attestation/quote-fixture.d.ts",
      "import": "./dist/attestation/quote-fixture.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run build && node ../../scripts/verify-npm-package.mjs ."
  },
  "dependencies": {
    "@piplabs/cdr-sdk": "0.2.1",
    "@storacha/client": "^1.8.26",
    "viem": "^2.47.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
