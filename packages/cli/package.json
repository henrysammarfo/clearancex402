{
  "name": "@line-stack/cli",
  "version": "0.1.1",
  "description": "Line Stack CLI — Vaultline & Queryline on Story CDR",
  "type": "module",
  "license": "MIT",
  "author": "Line Stack",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henrysammarfo/linestack.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/henrysammarfo/linestack/issues",
  "homepage": "https://github.com/henrysammarfo/linestack/tree/main/packages/cli#readme",
  "keywords": ["story", "cdr", "cli", "vaultline", "queryline", "linestack"],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "linestack": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "postbuild": "node ../../scripts/ensure-shebang.mjs cli",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && node ../../scripts/verify-npm-package.mjs ."
  },
  "dependencies": {
    "@line-stack/sdk": "^0.1.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@line-stack/sdk": "file:../sdk",
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
