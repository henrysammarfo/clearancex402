{
  "name": "@line-stack/mcp-server",
  "version": "0.1.1",
  "description": "MCP server for Line Stack Vaultline & Queryline",
  "type": "module",
  "license": "MIT",
  "author": "Line Stack",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henrysammarfo/linestack.git",
    "directory": "packages/mcp-server"
  },
  "bugs": "https://github.com/henrysammarfo/linestack/issues",
  "homepage": "https://github.com/henrysammarfo/linestack/tree/main/packages/mcp-server#readme",
